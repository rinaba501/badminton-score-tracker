<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<key>CFBundleDisplayName</key>
	<string>Featherkeep</string>
	<key>CFBundleExecutable</key>
	<string>$(EXECUTABLE_NAME)</string>
	<key>CFBundleIdentifier</key>
	<string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
	<key>CFBundleInfoDictionaryVersion</key>
	<string>6.0</string>
	<key>CFBundleName</key>
	<string>$(PRODUCT_NAME)</string>
	<key>CFBundlePackageType</key>
	<string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
	<key>CFBundleShortVersionString</key>
	<string>$(MARKETING_VERSION)</string>
	<!-- Same custom scheme the Watch app registers. On iOS it carries the
	     Friends invite link (badminton://addfriend, Roadmap 7d); the Watch's
	     badminton://newmatch complication deep link is not handled here. -->
	<key>CFBundleURLTypes</key>
	<array>
		<dict>
			<key>CFBundleURLSchemes</key>
			<array>
				<string>badminton</string>
			</array>
		</dict>
	</array>
	<key>CFBundleVersion</key>
	<string>$(CURRENT_PROJECT_VERSION)</string>
	<key>UIApplicationSceneManifest</key>
	<dict>
		<key>UIApplicationSupportsMultipleScenes</key>
		<false/>
	</dict>
	<key>UILaunchScreen</key>
	<dict/>
	<!-- Landscape is declared here but gated at runtime: AppDelegate's
	     supportedInterfaceOrientationsFor keeps the whole app portrait except
	     while the landscape-native Scoreboard game style is on screen. -->
	<key>UISupportedInterfaceOrientations</key>
	<array>
		<string>UIInterfaceOrientationPortrait</string>
		<string>UIInterfaceOrientationLandscapeLeft</string>
		<string>UIInterfaceOrientationLandscapeRight</string>
	</array>
	<!-- DSEG7 Classic Bold (SIL OFL licensed, see Fonts/DSEG-LICENSE.txt at repo
	     root) — the 7-segment LED font used by the LED Board GameScreenStyle's
	     ledDigit so the ghost "unlit segment" overlay reads as a real digital
	     scoreboard glyph, not two unrelated numeral shapes stacked. -->
	<key>UIAppFonts</key>
	<array>
		<string>DSEG7Classic-Bold.ttf</string>
	</array>
	<!-- AdMob (banner ads for non-Pro users, iOS only). This is Google's
	     public TEST application ID — replace with the real AdMob app ID
	     (and the ad-unit ID in AdBannerView.swift) before release. -->
	<key>GADApplicationIdentifier</key>
	<string>ca-app-pub-3940256099942544~1458002511</string>
	<key>NSUserTrackingUsageDescription</key>
	<string>This identifier will be used to show you more relevant ads. Denying keeps ads non-personalized.</string>
	<key>SKAdNetworkItems</key>
	<array>
		<dict>
			<key>SKAdNetworkIdentifier</key>
			<string>cstr6suwn9.skadnetwork</string>
		</dict>
	</array>
</dict>
</plist>
