import Foundation

// Copy this file to SupabaseSpikeSecrets.swift (gitignored, sits next to this
// file) and fill in your own Supabase project's values.
extension SupabaseSpikeConfig {
    static let projectURL = URL(string: "https://YOUR-PROJECT-REF.supabase.co")!
    static let anonKey = "YOUR-PUBLISHABLE-KEY"

    /// Must match a URL scheme registered in both targets' Info.plist and the
    /// redirect URL allow-list in the Supabase Auth dashboard.
    static let authCallbackURL = URL(string: "badminton://auth-callback")!
}
